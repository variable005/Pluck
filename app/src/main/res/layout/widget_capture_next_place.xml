<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_capture_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_capture_background"
    android:clickable="true"
    android:contentDescription="@string/widget_capture_content_description"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="16dp"
    android:paddingEnd="20dp"
    android:paddingBottom="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:letterSpacing="0.12"
        android:text="@string/widget_brand"
        android:textAllCaps="true"
        android:textColor="@color/widget_on_surface_muted"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/widget_capture_title"
        android:textColor="@color/widget_on_surface"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_local_readiness"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/widget_on_surface"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_local_details"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/widget_on_surface_muted"
        android:textSize="12sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/widget_battery_guidance"
        android:textColor="@color/widget_on_surface_muted"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/widget_capture_action"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/widget_capture_action_background"
        android:clickable="true"
        android:gravity="center"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="@string/widget_capture_action"
        android:textAllCaps="true"
        android:textColor="@color/widget_on_action"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>
